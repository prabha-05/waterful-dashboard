generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}

model SalesOrder {
  id           Int      @id @default(autoincrement())
  month        String
  duplicate    Int
  orderId      Int
  date         DateTime
  flavour      String
  qty          Int
  customerName String
  mobile       String
  billingCity  String
  pincode      String
  billingState String
  total        Float
  status       String
  paymentMethod String?
}

model ShopifyOrder {
  id              Int      @id @default(autoincrement())
  shopifyId       BigInt   @unique
  orderNumber     Int
  email           String?
  customerName    String
  phone           String?
  totalPrice      Float
  subtotalPrice   Float
  totalTax        Float
  currency        String   @default("INR")
  financialStatus String
  fulfillmentStatus String?
  createdAt       DateTime
  updatedAt       DateTime
  processedAt     DateTime?
  cancelledAt     DateTime?
  closedAt        DateTime?
  billingCity     String?
  billingState    String?
  billingCountry  String?
  billingZip      String?
  shippingCity    String?
  shippingState   String?
  shippingCountry String?
  shippingZip     String?
  itemCount       Int      @default(0)
  note            String?
  tags            String?
  paymentGatewayNames String?
  discountCodes       String?
  totalDiscounts      Float?
  syncedAt        DateTime @default(now())

  lineItems       ShopifyLineItem[]
}

model ShopifyLineItem {
  id          Int      @id @default(autoincrement())
  shopifyId   BigInt   @unique
  orderId     Int
  title       String
  variantTitle String?
  sku         String?
  quantity    Int
  price       Float
  totalDiscount Float  @default(0)
  vendor      String?
  productId   BigInt?

  order       ShopifyOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model SyncLog {
  id          Int      @id @default(autoincrement())
  startedAt   DateTime @default(now())
  completedAt DateTime?
  status      String   @default("running")
  ordersAdded Int      @default(0)
  ordersUpdated Int    @default(0)
  error       String?
}

model MetaCampaign {
  id              Int      @id @default(autoincrement())
  metaCampaignId  String   @unique
  name            String
  status          String
  objective       String?
  dailyBudget     Float?
  lifetimeBudget  Float?
  startTime       DateTime?
  stopTime        DateTime?
  createdTime     DateTime
  updatedTime     DateTime
  syncedAt        DateTime @default(now())

  spendDays       MetaAdSpendDaily[]
}

model MetaAdSpendDaily {
  id            Int      @id @default(autoincrement())
  campaignId    Int
  date          DateTime
  spend         Float    @default(0)
  impressions   Int      @default(0)
  reach         Int      @default(0)
  clicks        Int      @default(0)
  ctr           Float    @default(0)
  cpc           Float    @default(0)
  cpm           Float    @default(0)
  purchases     Int      @default(0)
  purchaseValue Float    @default(0)
  syncedAt      DateTime @default(now())

  campaign      MetaCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, date])
}

model MetaAdSet {
  id                Int      @id @default(autoincrement())
  metaAdSetId       String   @unique
  metaCampaignId    String
  name              String
  status            String
  effectiveStatus   String?
  optimizationGoal  String?
  billingEvent      String?
  dailyBudget       Float?
  lifetimeBudget    Float?
  targetingSummary  String?
  startTime         DateTime?
  endTime           DateTime?
  createdTime       DateTime
  updatedTime       DateTime
  syncedAt          DateTime @default(now())

  spendDays         MetaAdSetDaily[]
  ads               MetaAd[]
}

model MetaAdSetDaily {
  id            Int      @id @default(autoincrement())
  adSetId       Int
  date          DateTime
  spend         Float    @default(0)
  impressions   Int      @default(0)
  reach         Int      @default(0)
  clicks        Int      @default(0)
  ctr           Float    @default(0)
  cpc           Float    @default(0)
  cpm           Float    @default(0)
  frequency     Float    @default(0)
  purchases     Int      @default(0)
  purchaseValue Float    @default(0)
  syncedAt      DateTime @default(now())

  adSet         MetaAdSet @relation(fields: [adSetId], references: [id], onDelete: Cascade)

  @@unique([adSetId, date])
}

model MetaAd {
  id                Int      @id @default(autoincrement())
  metaAdId          String   @unique
  adSetId           Int
  name              String
  status            String
  effectiveStatus   String?
  creativeId        String?
  creativeName      String?
  creativeType      String?
  thumbnailUrl      String?
  previewLink       String?
  createdTime       DateTime
  updatedTime       DateTime
  syncedAt          DateTime @default(now())

  adSet             MetaAdSet @relation(fields: [adSetId], references: [id], onDelete: Cascade)
  spendDays         MetaAdDaily[]
}

model MetaAdDaily {
  id                       Int      @id @default(autoincrement())
  adId                     Int
  date                     DateTime
  spend                    Float    @default(0)
  impressions              Int      @default(0)
  reach                    Int      @default(0)
  clicks                   Int      @default(0)
  ctr                      Float    @default(0)
  cpc                      Float    @default(0)
  cpm                      Float    @default(0)
  frequency                Float    @default(0)
  video3sViews             Int      @default(0)
  videoP75Views            Int      @default(0)
  purchases                Int      @default(0)
  purchaseValue            Float    @default(0)
  qualityRanking           String?
  engagementRateRanking    String?
  conversionRateRanking    String?
  syncedAt                 DateTime @default(now())

  ad                       MetaAd @relation(fields: [adId], references: [id], onDelete: Cascade)

  @@unique([adId, date])
}
